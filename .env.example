# MinerU API 配置
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=

# MinerU 处理配置
MINERU_MAX_POLL_TIME=3600
MINERU_MAX_QUERY_ERRORS=10
MINERU_UPLOAD_TIMEOUT=60
MINERU_UPLOAD_MAX_RETRIES=2
MINERU_UPLOAD_RETRY_DELAY=10

# Kimi API 配置
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_TIMEOUT=300
KIMI_MAX_RETRIES=2
KIMI_RETRY_DELAY=5
KIMI_CONCURRENCY=4

# 图片存放目录（留空则使用 runs/{run_id}/assets）
ASSETS_DIR=

# 图片链接配置（留空则使用图片存放目录的相对链接）
IMAGE_BASE_URL=

# MinerU Markdown 脱敏配置
SANITIZE_ENABLED=false
SANITIZE_ENTITIES_PATH=data/private/sensitive_entities.json

# 最终输出文件格式，可选 md 或 txt
OUTPUT_FORMAT=md
