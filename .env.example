# MinerU API 配置
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=

# MinerU 处理配置
MINERU_MAX_POLL_TIME=3600
MINERU_MAX_QUERY_ERRORS=10

# Kimi API 配置
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_TIMEOUT=300
KIMI_MAX_RETRIES=2
KIMI_RETRY_DELAY=5

# 图片处理配置（留空则跳过图片移动和链接更新）
IMAGE_BASE_URL=
IMAGE_TARGET_DIR=

# 最终输出文件格式，可选 md 或 txt
OUTPUT_FORMAT=md
